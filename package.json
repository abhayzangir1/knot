{
  "name": "knot-slack-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Knot is a Slack-native outcome coordinator that ties up loose ends safely.",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:postgres": "node scripts/run-postgres-tests.mjs",
    "measure:ack": "node scripts/measure-slack-ack.mjs",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "db:migrate": "tsx src/db/migrate.ts",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@slack/bolt": "^4.7.3",
    "@slack/web-api": "^7.19.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
